<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="cs_pos_smart_cash_cashdro.CashdropPendingDialog">
        <Dialog title="'Pago en Cashdrop'" size="'lg'" class="cashdrop-pending-dialog-attractive">
            <div class="cashdrop-pending-body text-center py-5 px-4">
                <div class="cashdrop-icon-wrapper mb-4">
                    <i class="fa fa-money fa-4x text-success" aria-hidden="true"/>
                </div>
                <h2 class="mb-3 fw-bold text-dark">Pague en la máquina Cashdro</h2>
                <p class="lead text-muted mb-0 mx-auto" style="max-width: 22em;">
                    Inserte el efectivo en la máquina. La orden se confirmará automáticamente al completar el pago.
                </p>
            </div>
        </Dialog>
    </t>
</templates>
