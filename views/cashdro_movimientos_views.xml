<?xml version="1.0" encoding="utf-8"?>
<openerp>
    <record id="view_cashdro_caja_movimientos_form" model="ir.ui.view">
        <field name="name">cashdro.caja.movimientos.form</field>
        <field name="model">cashdro.caja.movimientos</field>
        <field name="arch" type="xml">
            <form string="Movimientos">
                <sheet>
                    <group>
                        <group string="Caja">
                            <field name="payment_method_id" options="{'no_create': True}"/>
                            <field name="last_refresh" readonly="1"/>
                            <button name="action_consultar_fianza" string="Consultar fianza" type="object" class="btn-primary"/>
                            <button name="action_consulta_niveles" string="Consulta niveles" type="object" class="btn-secondary"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Estado de fianza" name="state_fianza">
                            <group col="1" string="Estado de fianza">
                                <field name="state_fianza" nolabel="1"/>
                            </group>
                        </page>
                        <page string="Estado niveles" name="state_niveles">
                            <group col="1" string="Consulta de niveles">
                                <field name="state_display" nolabel="1"/>
                            </group>
                        </page>
                        <page string="Movimientos" name="movimientos">
                            <group string="Operaciones">
                                <div class="row mt-3">
                                    <button name="action_pago" string="Venta" type="object" class="btn-secondary"/>
                                    <button name="action_cambio" string="Cambio" type="object" class="btn-secondary"/>
                                    <button name="action_devolucion" string="Pago" type="object" class="btn-secondary"/>
                                    <button name="action_ingresar" string="Ingresar" type="object" class="btn-secondary"/>
                                    <button name="action_ingreso_importe" string="Ingresar por importe" type="object" class="btn-secondary"/>
                                    <button name="action_carga" string="Carga" type="object" class="btn-secondary"/>
                                    <button name="action_retirada" string="Retirada" type="object" class="btn-secondary"/>
                                    <button name="action_retirada_casete_monedas" string="Retirada de casete de monedas" type="object" class="btn-secondary"/>
                                    <button name="action_retirada_casete_billetes" string="Retirada de casete de billetes" type="object" class="btn-secondary"/>
                                    <button name="action_inicializar_niveles" string="Inicializar niveles" type="object" class="btn-secondary"/>
                                    <button name="action_configurar_fianza" string="Configurar fianza" type="object" class="btn-secondary"/>
                                </div>
                            </group>
                        </page>
                        <page string="Debug" name="debug">
                            <field name="state_raw" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

