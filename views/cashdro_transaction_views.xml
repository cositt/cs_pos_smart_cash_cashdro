<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista árbol para transacciones -->
    <record id="view_cashdro_transaction_tree" model="ir.ui.view">
        <field name="name">cashdro.transaction.tree</field>
        <field name="model">cashdro.transaction</field>
        <field name="arch" type="xml">
            <tree string="Transacciones Cashdrop" decoration-success="status == 'confirmed'" decoration-danger="status == 'error'" decoration-warning="status == 'processing'">
                <field name="name"/>
                <field name="transaction_id"/>
                <field name="operation_id"/>
                <field name="order_id"/>
                <field name="amount" sum="Monto Total"/>
                <field name="amount_received" sum="Total Recibido"/>
                <field name="status"/>
                <field name="create_date"/>
            </tree>
        </field>
    </record>

    <!-- Vista formulario para transacciones -->
    <record id="view_cashdro_transaction_form" model="ir.ui.view">
        <field name="name">cashdro.transaction.form</field>
        <field name="model">cashdro.transaction</field>
        <field name="arch" type="xml">
            <form string="Transacción Cashdrop">
                <header>
                    <button name="action_confirm" type="object" string="Confirmar" class="btn-success" attrs="{'invisible': [('status', 'not in', ['processing', 'error'])]}"/>
                    <button name="action_cancel" type="object" string="Cancelar" class="btn-danger" attrs="{'invisible': [('status', 'not in', ['processing', 'error'])]}"/>
                    <button name="action_retry" type="object" string="Reintentar" class="btn-warning" attrs="{'invisible': [('status', 'not in', ['error', 'timeout', 'cancelled'])]}"/>
                    <field name="status" widget="statusbar" options="{'clickable': false}"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="toggle_active" type="object" class="oe_stat_button" icon="fa-archive">
                            <field name="active" widget="boolean_button" options='{"terminology": "archive"}' invisible="True"/>
                        </button>
                    </div>
                    <h1>
                        <field name="name" readonly="True"/>
                    </h1>
                    <group>
                        <group string="Información General">
                            <field name="transaction_id" readonly="True"/>
                            <field name="order_id" readonly="True"/>
                            <field name="payment_method_id" readonly="True"/>
                            <field name="operation_id" readonly="True"/>
                        </group>
                        <group string="Monto">
                            <field name="amount" readonly="True"/>
                            <field name="currency_id" readonly="True"/>
                            <field name="amount_received" readonly="True"/>
                        </group>
                        <group string="Auditoría">
                            <field name="user_id" readonly="True"/>
                            <field name="pos_session_id" readonly="True"/>
                            <field name="create_date" readonly="True"/>
                        </group>
                        <group string="Timestamps">
                            <field name="confirmed_at" readonly="True"/>
                            <field name="cancelled_at" readonly="True"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Datos Técnicos">
                            <group>
                                <field name="response_data" nolabel="True" readonly="True" widget="ace" options="{'mode': 'json'}"/>
                            </group>
                        </page>
                        <page string="Errores">
                            <group>
                                <field name="error_message" nolabel="True" readonly="True" attrs="{'invisible': [('error_message', '=', False)]}"/>
                                <div attrs="{'invisible': [('error_message', '!=', False)]}">
                                    <p>Sin errores</p>
                                </div>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vista de búsqueda para transacciones -->
    <record id="view_cashdro_transaction_search" model="ir.ui.view">
        <field name="name">cashdro.transaction.search</field>
        <field name="model">cashdro.transaction</field>
        <field name="arch" type="xml">
            <search string="Transacciones Cashdrop">
                <field name="name"/>
                <field name="transaction_id"/>
                <field name="operation_id"/>
                <field name="order_id"/>
                <field name="status"/>
                <separator/>
                <filter string="Procesando" name="filter_processing" domain="[('status', '=', 'processing')]"/>
                <filter string="Confirmado" name="filter_confirmed" domain="[('status', '=', 'confirmed')]"/>
                <filter string="Cancelado" name="filter_cancelled" domain="[('status', '=', 'cancelled')]"/>
                <filter string="Error" name="filter_error" domain="[('status', 'in', ['error', 'timeout'])]"/>
                <separator/>
                <filter string="Hoy" name="filter_today" domain="[('create_date', '>=', context_today().strftime('%Y-%m-%d 00:00:00')), ('create_date', '&lt;=', context_today().strftime('%Y-%m-%d 23:59:59'))]"/>
                <filter string="Esta Semana" name="filter_week" domain="[('create_date', '&gt;=', (context_today() - timedelta(days=7)).strftime('%Y-%m-%d'))]"/>
                <group expand="1" string="Agrupar por">
                    <filter string="Estado" name="group_status" domain="[]" context="{'group_by': 'status'}"/>
                    <filter string="Método de Pago" name="group_payment" domain="[]" context="{'group_by': 'payment_method_id'}"/>
                    <filter string="Usuario" name="group_user" domain="[]" context="{'group_by': 'user_id'}"/>
                    <filter string="Fecha" name="group_date" domain="[]" context="{'group_by': 'create_date'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Acción para transacciones -->
    <record id="action_cashdro_transaction" model="ir.actions.act_window">
        <field name="name">Transacciones Cashdrop</field>
        <field name="res_model">cashdro.transaction</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_cashdro_transaction_search"/>
        <field name="context">{"search_default_filter_processing": 1}</field>
    </record>
</odoo>
