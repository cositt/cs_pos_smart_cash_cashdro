<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <menuitem id="menu_cashdro_root" name="Cashdrop" web_icon="cs_pos_smart_cash_cashdro,static/description/icon.png" groups="point_of_sale.group_pos_manager" sequence="100"/>
        <menuitem id="menu_cashdro_transactions" name="Transacciones" parent="menu_cashdro_root" action="action_cashdro_transaction" sequence="10"/>
        <menuitem id="menu_cashdro_payment_methods" name="Métodos de Pago" parent="menu_cashdro_root" action="action_pos_payment_method_cashdro" sequence="20"/>
        <record id="action_cashdro_caja_movimientos" model="ir.actions.server">
            <field name="name">Movimientos</field>
            <field name="model_id" ref="base.model_res_users"/>
            <field name="state">code</field>
            <field name="code">method = env['pos.payment.method'].search([('cashdro_enabled','=',True)], limit=1) or env['pos.payment.method'].search([], limit=1)
action = env['cashdro.caja.movimientos'].create({'payment_method_id': method.id} if method else {}).action_open_form()</field>
        </record>
        <menuitem id="menu_cashdro_movimientos" name="Movimientos" parent="menu_cashdro_root" action="action_cashdro_caja_movimientos" sequence="5"/>
    </data>
</odoo>
