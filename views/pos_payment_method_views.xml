<?xml version="1.0" encoding="utf-8"?>
<openerp>
    <record id="view_pos_payment_method_form" model="ir.ui.view">
        <field name="name">pos.payment.method.form.cashdro</field>
        <field name="model">pos.payment.method</field>
        <field name="inherit_id" ref="point_of_sale.pos_payment_method_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form/sheet" position="inside">
                <group string="Configuración Cashdrop">
                    <group string="Habilitación">
                        <field name="cashdro_enabled"/>
                    </group>
                    <group string="Conexión" invisible="not cashdro_enabled">
                        <field name="cashdro_host" placeholder="10.0.1.140"/>
                        <field name="cashdro_user" placeholder="username"/>
                        <field name="cashdro_password" password="True" placeholder="password"/>
                        <field name="cashdro_gateway_url" placeholder="https://10.0.1.140"/>
                    </group>
                </group>
                <group string="Estado de Conexión" invisible="not cashdro_enabled">
                    <field name="cashdro_connection_status" readonly="1"/>
                    <field name="cashdro_last_check" readonly="1"/>
                    <field name="cashdro_error_message" readonly="1" nolabel="1"/>
                    <button name="action_test_connection" type="object" string="Probar Conexión" class="btn-primary"/>
                    <button name="action_get_payment_info" type="object" string="Info de Pago" class="btn-secondary"/>
                </group>
            </xpath>
        </field>
    </record>

    <!-- Vista lista para pos.payment.method -->
    <record id="view_pos_payment_method_tree" model="ir.ui.view">
        <field name="name">pos.payment.method.tree.cashdro</field>
        <field name="model">pos.payment.method</field>
        <field name="inherit_id" ref="point_of_sale.pos_payment_method_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="inside">
                <field name="cashdro_enabled" optional="hide"/>
                <field name="cashdro_connection_status" optional="hide"/>
            </xpath>
        </field>
    </record>

    <!-- Acción para abrir métodos de pago -->
    <record id="action_pos_payment_method_cashdro" model="ir.actions.act_window">
        <field name="name">Métodos de Pago</field>
        <field name="res_model">pos.payment.method</field>
        <field name="view_mode">list,form</field>
        <field name="context">{"search_default_cashdro_enabled": 1}</field>
    </record>
</openerp>
