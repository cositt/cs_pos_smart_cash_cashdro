<?xml version="1.0" encoding="utf-8"?>
<openerp>
    <record id="view_res_config_settings_form" model="ir.ui.view">
        <field name="name">res.config.settings.form.cashdro</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="50"/>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Cashdrop" string="Cashdrop" name="cashdro">
                    <block title="Configuración General">
                        <setting string="Habilitar Cashdrop" help="Activar integración con máquinas Cashdrop">
                            <field name="cashdro_enabled"/>
                        </setting>
                    </block>
                    <block title="Conexión" invisible="not cashdro_enabled">
                        <setting string="Host/IP" help="IP de la máquina Cashdrop">
                            <field name="cashdro_default_host" placeholder="10.0.1.140"/>
                        </setting>
                        <setting string="Usuario" help="Usuario de autenticación">
                            <field name="cashdro_default_user"/>
                        </setting>
                        <setting string="Contraseña" help="Contraseña de autenticación">
                            <field name="cashdro_default_password" password="True"/>
                        </setting>
                        <setting string="URL Gateway" help="URL completa del gateway">
                            <field name="cashdro_default_gateway_url" placeholder="https://10.0.1.140"/>
                        </setting>
                    </block>
                    <block title="Timeouts" invisible="not cashdro_enabled">
                        <setting string="Timeout Conexión" help="Segundos máximos de espera">
                            <field name="cashdro_connection_timeout"/>
                        </setting>
                        <setting string="Timeout Polling" help="Segundos máximos en polling">
                            <field name="cashdro_polling_timeout"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</openerp>
