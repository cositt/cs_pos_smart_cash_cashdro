<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_cashdro_config_wizard_form" model="ir.ui.view">
        <field name="name">cashdro.config.wizard.form</field>
        <field name="model">cashdro.config.wizard</field>
        <field name="arch" type="xml">
            <form string="Configuración Cashdrop">
                <sheet>
                    <group>
                        <group string="General">
                            <field name="cashdro_enabled"/>
                            <field name="cashdro_default_gateway_url" attrs="{'invisible': [('cashdro_enabled', '=', False)]}" placeholder="https://10.0.1.140"/>
                        </group>
                        <group string="Comunicación" attrs="{'invisible': [('cashdro_enabled', '=', False)]}">
                            <field name="cashdro_connection_timeout"/>
                            <field name="cashdro_polling_timeout"/>
                            <field name="cashdro_polling_interval"/>
                            <field name="cashdro_verify_ssl"/>
                        </group>
                    </group>
                    <group attrs="{'invisible': [('cashdro_enabled', '=', False)]}">
                        <group string="Reintentos">
                            <field name="cashdro_max_retries"/>
                            <field name="cashdro_retry_delay"/>
                        </group>
                        <group string="Operaciones">
                            <field name="cashdro_auto_confirm_payments"/>
                            <field name="cashdro_log_level"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button name="action_apply" type="object" string="Guardar" class="btn-primary"/>
                    <button name="action_cancel" string="Cancelar" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_cashdro_config_wizard" model="ir.actions.act_window">
        <field name="name">Configuración Cashdrop</field>
        <field name="res_model">cashdro.config.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="view_cashdro_config_wizard_form"/>
        <field name="context">{}</field>
    </record>
</odoo>
